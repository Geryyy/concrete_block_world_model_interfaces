# Add or update a block in the world model.
# Called by the Gazebo bridge (simulation) or perception pipeline (real).
string block_id
geometry_msgs/Pose pose
string frame_id          # frame of the pose (e.g. "world")
int32 pose_status 1      # default POSE_COARSE
int32 task_status 1      # default TASK_FREE
float32 confidence 1.0
---
bool success
string message
